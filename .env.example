# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,contracts.elbouazzatiholding.ma

# Database (PostgreSQL)
DB_NAME=contracts_db
DB_USER=contracts_user
DB_PASSWORD=contracts_password
DB_HOST=db
DB_PORT=5432

# Redis (shared host Redis, DB 1)
CELERY_BROKER_URL=redis://host.docker.internal:6379/1
CHANNEL_LAYERS_URL=redis://host.docker.internal:6379/1

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# API
API_URL=https://contracts.elbouazzatiholding.ma
CORS_ALLOWED_ORIGINS=https://contracts.elbouazzatiholding.ma,http://localhost:3001

# Axes (brute-force protection)
AXES_FAILURE_LIMIT=5
